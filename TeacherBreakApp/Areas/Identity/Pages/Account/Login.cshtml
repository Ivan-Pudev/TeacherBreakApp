@page
@using Microsoft.AspNetCore.Identity.UI.V4.Pages.Account.Internal
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="login-wrapper">
    <div class="login-card">
        <div class="text-center mb-4">
            <div class="school-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <h2 class="fw-bold">Вход в системата</h2>
            <p class="text-muted small">Управление на отпуски на учители</p>
        </div>
        <section>
            <form id="account" method="post">
                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="mb-3 text-start">
                    <label asp-for="Input.Email" class="form-label fw-bold small">Потребителско име (Имейл)</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="Въведете имейл"/>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="mb-3 text-start">
                    <label asp-for="Input.Password" class="form-label fw-bold small">Парола</label>
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Въведете парола" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div>
                    <button id="login-submit" type="submit" class="btn btn-dark-custom w-100 mt-2">Вход</button>
                </div>
            </form>
        </section>
    </div>
