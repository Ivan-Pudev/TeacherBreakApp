@model List<LeaveBalance>

@{
    var months = new[]
    {
        "Януари", "Февруари", "Март", "Април", "Май", "Юни",
        "Юли", "Август", "Септември", "Октомври", "Ноември", "Декември"
    };
    int currentYear = DateTime.Now.Year;
}

<div class="container-fluid mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Административен панел</h2>
        <a asp-action="CreateTeacher" class="btn btn-dark" style="background-color: #0f172a;">
            Добави учител
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-3">
            <h5 class="card-title mb-4">Списък на учителите и отпуските (@currentYear)</h5>
            <div class="table-responsive">
                <table class="table table-bordered align-middle text-center small"
                       style="min-width: 1600px;">
                    <thead class="table-dark">
                        <tr>
                            <th rowspan="2" class="text-start align-middle px-3" style="min-width:160px;">
                                Име, фамилия
                            </th>
                            <th rowspan="2" class="align-middle" style="min-width:80px;">
                                Остатък отпуск
                            </th>
                            <th rowspan="2" class="align-middle" style="min-width:100px;">
                                Полагаем отпуск за @currentYear г.
                            </th>
                            <th rowspan="2" class="align-middle" style="min-width:80px;">
                                Доп. отпуск
                            </th>
                            <th rowspan="2" class="align-middle" style="min-width:70px;">
                                Общо
                            </th>
                            @foreach (var month in months)
                            {
                                <th colspan="2" class="align-middle" style="min-width:160px;">
                                    @month
                                </th>
                            }
                            <th rowspan="2" class="align-middle" style="min-width:90px;">
                                Общо използван
                            </th>
                            <th rowspan="2" class="align-middle" style="min-width:90px;">
                                Оставащи
                            </th>
                            <th rowspan="2" class="align-middle" style="min-width:120px;">
                                Действия
                            </th>
                        </tr>
                        <tr>
                            @foreach (var month in months)
                            {
                                <th style="min-width:70px;">Брой дни</th>
                                <th style="min-width:90px;">Дати</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lb in Model)
                        {
                            var totalDays = lb.CarryOverDays + lb.AnnualLeaveDays + lb.AdditionalLeaveDays;
                            var activeEntries = lb.LeaveEntries.Where(e => !e.IsDeleted).ToList();
                            var usedDays = activeEntries.Sum(e => e.Days);
                            var remainingDays = totalDays - usedDays;

                            <tr>
                                <td class="text-start fw-semibold px-3">@lb.Teacher.FullName</td>
                                <td>@lb.CarryOverDays</td>
                                <td>@lb.AnnualLeaveDays</td>
                                <td>@lb.AdditionalLeaveDays</td>
                                <td class="fw-bold">@totalDays</td>

                                @for (int m = 1; m <= 12; m++)
                                {
                                    var monthEntries = activeEntries
                                        .Where(e => e.StartDate.Month == m || e.EndDate.Month == m)
                                        .ToList();

                                    var monthDays = monthEntries.Sum(e =>
                                    {
                                        // Count only days within this month
                                        var start = e.StartDate.Month == m ? e.StartDate : new DateOnly(e.StartDate.Year, m, 1);
                                        var end = e.EndDate.Month == m ? e.EndDate : new DateOnly(e.EndDate.Year, m, DateTime.DaysInMonth(e.EndDate.Year, m));
                                        return end.DayNumber - start.DayNumber + 1;
                                    });

                                    var dateRanges = string.Join(", ", monthEntries.Select(e =>
                                    {
                                        // Format: 15–16.01 or 5.02
                                        if (e.StartDate == e.EndDate)
                                            return $"{e.StartDate.Day}.{e.StartDate.Month:D2}";
                                        return $"{e.StartDate.Day}–{e.EndDate.Day}.{e.EndDate.Month:D2}";
                                    }));

                                    <td class="@(monthDays > 0 ? "text-danger fw-semibold" : "text-muted")">
                                        @(monthDays > 0 ? monthDays.ToString() : "–")
                                    </td>
                                    <td class="text-nowrap @(monthDays > 0 ? "" : "text-muted")">
                                        @(string.IsNullOrEmpty(dateRanges) ? "–" : dateRanges)
                                    </td>
                                }

                                <td class="text-danger fw-bold">@usedDays</td>
                                <td class="fw-bold @(remainingDays < 0 ? "text-danger" : "text-success")">
                                    @remainingDays
                                </td>
                                <td>
                                    <a asp-action="EditLeave" asp-route-id="@lb.Id"
                                           class="btn btn-outline-secondary btn-sm rounded-pill px-2 shadow-sm mb-1">
                                        <i class="fas fa-pencil-alt me-1 small"></i> Редактирай
                                    </a>
                                    <form asp-action="DeleteLeave"
                                          asp-route-id="@lb.Id"
                                          method="post"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm rounded-pill px-2 shadow-sm"
                                                onclick="return confirm('Сигурни ли сте, че искате да изтриете този отпуск?');">
                                            <i class="fas fa-trash-alt me-1 small"></i> Изтрий
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>