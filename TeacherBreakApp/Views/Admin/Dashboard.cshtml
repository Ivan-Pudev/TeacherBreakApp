@model List<LeaveBalance>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Административен панел</h2>
        <a asp-action="CreateTeacher" class="btn btn-dark" style="background-color: #0f172a;">
            Добави учител
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <h5 class="card-title mb-4">Списък на учителите и отпуските</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="text-muted small">
                        <tr>
                            <th>Име</th>
                            <th>Имейл</th>
                            <th class="text-center">Общо дни</th>
                            <th class="text-center">Използвани</th>
                            <th class="text-center">Оставащи</th>
                            <th class="text-end px-4">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lb in Model)
                        {
                            var totalDays = lb.CarryOverDays + lb.AnnualLeaveDays + lb.AdditionalLeaveDays;
                            var usedDays = lb.LeaveEntries
                                .Where(e => !e.IsDeleted)
                                .Sum(e => e.Days);
                            var remainingDays = totalDays - usedDays;

                            <tr>
                                <td class="fw-bold">@lb.Teacher.FullName</td>
                                <td class="text-muted small">@lb.Teacher.Email</td>
                                <td class="text-center">@totalDays</td>
                                <td class="text-center text-danger">@usedDays</td>
                                <td class="text-center fw-bold">@remainingDays</td>
                                <td class="text-end px-4">
                                    <a asp-action="EditLeave" asp-route-id="@lb.Id"
                                           class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm">
                                        <i class="fas fa-pencil-alt me-1 small"></i> Редактирай
                                    </a>
                                    <form asp-action="DeleteLeave"
                                          asp-route-id="@lb.Id"
                                          method="post"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm"
                                                onclick="return confirm('Сигурни ли сте, че искате да изтриете този отпуск?');">
                                            <i class="fas fa-trash-alt me-1 small"></i> Изтрий
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>