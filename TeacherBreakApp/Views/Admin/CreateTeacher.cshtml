@model CreateTeacherViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-dark text-white rounded-circle mb-3"
                         style="width: 50px; height: 50px;">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <h3 class="fw-bold">Добавяне на учител</h3>
                    <p class="text-muted small">Въведете данни за нов акаунт</p>
                </div>

                <form asp-action="CreateTeacher" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <p class="fw-bold small text-uppercase text-muted mb-2 border-bottom pb-1">
                        Акаунт
                    </p>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Пълно име</label>
                        <input asp-for="FullName" class="form-control border-light-subtle py-2"
                               placeholder="напр. Иван Петров" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Имейл адрес</label>
                        <input asp-for="Email" type="email" class="form-control border-light-subtle py-2"
                               placeholder="ivan@school.bg" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Временна парола</label>
                        <input asp-for="Password" type="password" class="form-control border-light-subtle py-2"
                               placeholder="Минимум 6 символа" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <p class="fw-bold small text-uppercase text-muted mb-2 border-bottom pb-1">
                        Отпуск
                    </p>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Година</label>
                        <input asp-for="Year" type="number" class="form-control border-light-subtle py-2" />
                        <span asp-validation-for="Year" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-4">
                            <label class="form-label fw-bold small">Пренесени дни</label>
                            <input asp-for="CarryOverDays" type="number" min="0"
                                   class="form-control border-light-subtle py-2 text-center" />
                            <span asp-validation-for="CarryOverDays" class="text-danger small"></span>
                        </div>
                        <div class="col-4">
                            <label class="form-label fw-bold small">Полагаем отпуск</label>
                            <input asp-for="AnnualLeaveDays" type="number" min="0"
                                   class="form-control border-light-subtle py-2 text-center" />
                            <span asp-validation-for="AnnualLeaveDays" class="text-danger small"></span>
                        </div>
                        <div class="col-4">
                            <label class="form-label fw-bold small">Доп. отпуск</label>
                            <input asp-for="AdditionalLeaveDays" type="number" min="0"
                                   class="form-control border-light-subtle py-2 text-center" />
                            <span asp-validation-for="AdditionalLeaveDays" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="alert alert-secondary py-2 px-3 small mb-4">
                        Общо дни:
                        <strong id="totalPreview">
                            @(Model.CarryOverDays + Model.AnnualLeaveDays + Model.AdditionalLeaveDays)
                        </strong>
                    </div>

                    <div class="mt-2 d-grid gap-2">
                        <button type="submit" class="btn btn-dark py-2 fw-bold" style="background-color: #0f172a;">
                            Създай акаунт
                        </button>
                        <a asp-action="Dashboard" class="btn btn-link text-decoration-none text-muted small">
                            Отказ и връщане към списъка
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const carryOver = document.getElementById('CarryOverDays');
        const annual = document.getElementById('AnnualLeaveDays');
        const additional = document.getElementById('AdditionalLeaveDays');
        const preview = document.getElementById('totalPreview');

        function updateTotal() {
            const total = (parseInt(carryOver.value) || 0)
                        + (parseInt(annual.value) || 0)
                        + (parseInt(additional.value) || 0);
            preview.textContent = total;
        }

        carryOver.addEventListener('input', updateTotal);
        annual.addEventListener('input', updateTotal);
        additional.addEventListener('input', updateTotal);
    </script>
}