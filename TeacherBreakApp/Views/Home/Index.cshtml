@model LoginViewModel

@{
    ViewData["Title"] = "Вход в системата";
    Layout = "_Layout"; 
}

<style>
    body {
        background-color: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
        margin: 0;
    }

    .login-card {
        background: white;
        padding: 2.5rem;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        width: 100%;
        max-width: 450px;
    }

    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .school-icon {
        background-color: #0f172a;
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 0.5rem;
    }

    .form-control {
        border: 1px solid #e2e8f0;
        padding: 0.75rem;
        border-radius: 8px;
    }

    .btn-login {
        background-color: #0f172a;
        color: white;
        border: none;
        padding: 0.75rem;
        border-radius: 8px;
        font-weight: 600;
        width: 100%;
        margin-top: 1rem;
        transition: background-color 0.2s;
    }

        .btn-login:hover {
            background-color: #1e293b;
            color: white;
        }

    .test-accounts-box {
        background-color: #f1f5f9;
        border-radius: 8px;
        padding: 1rem;
        margin-top: 2rem;
        font-size: 0.85rem;
        color: #64748b;
    }
</style>

<div class="login-card">
    <div class="login-header">
        <div class="school-icon">
            <i class="fas fa-user-graduate"></i>
        </div>
        <h3 class="fw-bold">Вход в системата</h3>
        <p class="text-muted small">Управление на отпуски на учители</p>
    </div>

    <form asp-action="Login" method="post">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 small" role="alert">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Потребителско име (Имейл)</label>
            <input asp-for="Email" class="form-control" placeholder="Въведете потребителско име" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Парола</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Въведете парола" />
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-login">Вход</button>
    </form>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/your-code.js" crossorigin="anonymous"></script>
}