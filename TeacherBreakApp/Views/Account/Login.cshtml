@model LoginViewModel

<div class="login-wrapper">
    <div class="login-card">
        <div class="text-center mb-4">
            <div class="school-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <h2 class="fw-bold">Вход в системата</h2>
            <p class="text-muted small">Управление на отпуски на учители</p>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3 text-start">
                <label asp-for="Email" class="form-label fw-bold small">Потребителско име (Имейл)</label>
                <input asp-for="Email" class="form-control" placeholder="Въведете имейл" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3 text-start">
                <label asp-for="Password" class="form-label fw-bold small">Парола</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Въведете парола" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-dark-custom w-100 mt-2">Вход</button>
        </form>

    </div>
</div>
