{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=TeacherBreakApp;Trusted_Connection=True;Encrypt=False;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Identity": {
      "Password": {
        "RequireDigit": true,
        "RequiredLength": 8,
        "RequiredUniqueChars": 3,
        "RequireNonAlphanumeric": true,
        "RequireUppercase": true,
        "RequireLowercase": true
      },
      "SignIn": {
        "RequireConfirmedEmail": true,
        "RequireConfirmedPhoneNumber": true,
        "RequireConfirmedAccount": true
      }
    }
  },
  "AllowedHosts": "*"
}
